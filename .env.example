# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where the app is hosted (auto-set by Render)
APP_URL="MY_APP_URL"

# --- PostgreSQL / Supabase Database ---
# Create a free Supabase project at https://supabase.com
# Go to Project Settings > Database > Connection string to get these values
SQL_HOST="db.<your-project-ref>.supabase.co"
SQL_PORT=5432
SQL_USER="postgres"
SQL_PASSWORD="your-database-password"
SQL_DB_NAME="postgres"
SQL_SSL="true"
